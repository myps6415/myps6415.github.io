---
import Base from "./Base.astro";
import type { Locale } from "../i18n/strings";
import { postPath, blogIndexPath } from "../data/posts";

interface MetaItem {
  text: string;
  href?: string;
}

interface Props {
  lang: Locale;
  slug: string;
  title: string;
  description: string;
  tag: string;
  date: string;
  meta?: MetaItem[];
}

const { lang, slug, title, description, tag, date, meta = [] } = Astro.props;

const indexHref = blogIndexPath(lang);
const backLabel = lang === "zh" ? "← 回文章列表" : "← All posts";

const alternateUrls = {
  en: postPath(slug, "en"),
  zh: postPath(slug, "zh"),
};

const docTitle = lang === "zh" ? `${title} — 童曉瑜` : `${title} — John Tung`;
---

<Base
  title={docTitle}
  description={description}
  lang={lang}
  alternateUrls={alternateUrls}
>
  <main class="px-6 md:px-10 py-20 md:py-24">
    <article class="max-w-3xl mx-auto">
      <a
        href={indexHref}
        class="font-mono text-xs text-ink-500 hover:text-ink-900 transition-colors"
      >
        {backLabel}
      </a>

      <header class="mt-8 mb-12 pb-10 border-b border-ink-200">
        <span
          class="inline-block font-mono text-[11px] uppercase tracking-widest text-ink-500 border border-ink-200 rounded-full px-2.5 py-1 mb-6"
        >
          {tag}
        </span>
        <h1
          class="text-2xl md:text-[1.95rem] font-semibold tracking-tight text-ink-900 leading-[1.3]"
        >
          {title}
        </h1>
        <p class="mt-5 text-ink-700 leading-relaxed">{description}</p>
        <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 font-mono text-[12px] text-ink-500">
          <span>{date}</span>
          {
            meta.map((m) =>
              m.href ? (
                <a
                  href={m.href}
                  target="_blank"
                  rel="noreferrer"
                  class="text-ink-500 hover:text-ink-900 transition-colors border-b border-ink-200 hover:border-ink-500"
                >
                  {m.text}
                </a>
              ) : (
                <span>{m.text}</span>
              ),
            )
          }
        </div>
      </header>

      <div class="blog-prose">
        <slot />
      </div>
    </article>
  </main>
</Base>
