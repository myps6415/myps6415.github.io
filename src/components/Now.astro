---
import Section from "./Section.astro";
import type { SiteContent } from "../i18n/strings";

interface Props {
  data: SiteContent["now"];
}

const { data } = Astro.props;
---

<Section id="now" label={data.label}>
  <h2
    class="text-2xl md:text-3xl font-semibold tracking-tight text-ink-900 mb-10"
  >
    {data.intro}
  </h2>

  <ul class="space-y-7">
    {
      data.items.map((item) => (
        <li>
          <h3 class="text-lg font-semibold text-ink-900 mb-1.5 tracking-tight">
            {item.title}
          </h3>
          <p class="text-ink-700 leading-relaxed">{item.body}</p>
        </li>
      ))
    }
  </ul>
</Section>
