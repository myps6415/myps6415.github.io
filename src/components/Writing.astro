---
import Section from "./Section.astro";
import type { Locale, SiteContent } from "../i18n/strings";
import { posts, postPath, blogIndexPath } from "../data/posts";

interface Props {
  data: SiteContent["writing"];
  lang: Locale;
  limit?: number;
}

const { data, lang, limit = 3 } = Astro.props;

const visible = posts.slice(0, limit);
const indexHref = blogIndexPath(lang);
---

<Section id="writing" label={data.label}>
  <h2
    class="text-2xl md:text-3xl font-semibold tracking-tight text-ink-900 mb-10"
  >
    {data.intro}
  </h2>

  <ul class="divide-y divide-ink-200 border-t border-b border-ink-200">
    {
      visible.map((p) => {
        const loc = p[lang];
        const href = postPath(p.slug, lang);
        return (
          <li>
            <a
              href={href}
              class="group block py-5 md:py-6 transition-colors hover:bg-white -mx-3 px-3 rounded-md"
            >
              <div class="flex items-baseline justify-between gap-4 mb-2 flex-wrap">
                <span class="font-mono text-[11px] uppercase tracking-widest text-ink-500">
                  {loc.tag}
                </span>
                <span class="font-mono text-[11px] text-ink-500">{p.date}</span>
              </div>
              <h3 class="text-lg md:text-xl font-semibold text-ink-900 tracking-tight leading-snug mb-2 group-hover:underline underline-offset-4 decoration-ink-300">
                {loc.title}
              </h3>
              <p class="text-ink-700 leading-relaxed text-[0.95rem]">
                {loc.description}
              </p>
            </a>
          </li>
        );
      })
    }
  </ul>

  {
    posts.length > visible.length && (
      <div class="mt-6">
        <a
          href={indexHref}
          class="font-mono text-xs text-ink-500 hover:text-ink-900 transition-colors"
        >
          {data.readMore}
        </a>
      </div>
    )
  }
</Section>
