---
import Section from "./Section.astro";
import CaseStudy from "./CaseStudy.astro";
import type { SiteContent } from "../i18n/strings";

interface Props {
  data: SiteContent["work"];
}

const { data } = Astro.props;
---

<Section id="work" label={data.label}>
  <h2
    class="text-2xl md:text-3xl font-semibold tracking-tight text-ink-900 mb-10"
  >
    {data.intro}
  </h2>

  <div class="grid gap-5 md:gap-6">
    {
      data.cases.map((c) => (
        <CaseStudy
          metric={c.metric}
          metricLabel={c.metricLabel}
          title={c.title}
          body={c.body}
          tags={c.tags}
          href={c.href}
        />
      ))
    }
  </div>
</Section>
