---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="my-4 border border-ink-200 rounded-xl bg-white px-5 py-4">
  <div
    class="font-mono text-[11px] uppercase tracking-widest text-ink-500 mb-1.5"
  >
    {label}
  </div>
  <div class="text-ink-900 text-[0.95rem] leading-relaxed">
    <slot />
  </div>
</div>
