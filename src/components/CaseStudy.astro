---
interface Props {
  metric: string;
  metricLabel: string;
  title: string;
  body: string[];
  tags: string[];
}

const { metric, metricLabel, title, body, tags } = Astro.props;
---

<article
  class="group border border-ink-200 bg-white rounded-xl p-7 md:p-9 hover:border-ink-300 transition-colors"
>
  <div class="flex items-baseline gap-3 mb-6 flex-wrap">
    <span
      class="font-mono text-3xl md:text-4xl font-medium text-ink-900 tracking-tight"
    >
      {metric}
    </span>
    <span class="font-mono text-xs uppercase tracking-wider text-ink-500">
      {metricLabel}
    </span>
  </div>

  <h3 class="text-xl md:text-2xl font-semibold text-ink-900 mb-3 tracking-tight">
    {title}
  </h3>

  <div class="text-ink-700 leading-relaxed space-y-3">
    {body.map((p) => <p>{p}</p>)}
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="font-mono text-xs text-ink-500 border border-ink-200 rounded-full px-2.5 py-1">
          {tag}
        </span>
      ))
    }
  </div>
</article>
