---
import type { SiteContent } from "../i18n/strings";

interface Props {
  data: SiteContent["hero"];
}

const { data } = Astro.props;
---

<section class="px-6 md:px-10 pt-24 md:pt-32 pb-16 md:pb-20">
  <div class="max-w-3xl mx-auto">
    <p class="font-mono text-xs uppercase tracking-widest text-ink-500 mb-6">
      {data.eyebrow}
    </p>
    <h1
      class="text-4xl md:text-6xl font-semibold tracking-tight leading-[1.05] text-ink-900"
    >
      {data.headline1}<br />
      <span class="text-ink-500">{data.headline2}</span>
    </h1>
    <p class="mt-8 text-lg md:text-xl text-ink-700 leading-relaxed max-w-2xl">
      {data.body}
    </p>
  </div>
</section>
