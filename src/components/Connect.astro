---
import Section from "./Section.astro";
import type { SiteContent } from "../i18n/strings";

interface Props {
  data: SiteContent["connect"];
}

const { data } = Astro.props;

const isZh = Astro.url.pathname.startsWith("/zh");

const links = [
  {
    label: "CV",
    value: isZh ? "開放全遠端" : "Open to remote",
    href: isZh ? "/zh/cv" : "/cv",
  },
  { label: "GitHub", value: "@myps6415", href: "https://github.com/myps6415" },
  {
    label: "LinkedIn",
    value: "Hsiao-Yu Tung",
    href: "https://www.linkedin.com/in/hsiao-yu-tung-67547a119/",
  },
  { label: "Medium", value: "@myps6415", href: "https://medium.com/@myps6415" },
  {
    label: "Email",
    value: "myps6415@gmail.com",
    href: "mailto:myps6415@gmail.com",
  },
];
---

<Section id="connect" label={data.label} class="border-t border-ink-200">
  <h2
    class="text-2xl md:text-3xl font-semibold tracking-tight text-ink-900 mb-8"
  >
    {data.intro}
  </h2>

  <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="block min-w-0 border border-ink-200 rounded-lg px-5 py-4 hover:border-ink-500 hover:bg-white transition-colors"
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={
              link.href.startsWith("http") ? "noopener noreferrer" : undefined
            }
          >
            <span class="font-mono text-xs uppercase tracking-wider text-ink-500 block mb-1">
              {link.label}
            </span>
            <span class="text-ink-900 font-medium text-sm md:text-base block truncate">
              {link.value}
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  <p class="mt-16 font-mono text-xs text-ink-500">
    © {new Date().getFullYear()} John Tung. {data.footer}
  </p>
</Section>
