---
// 單篇 Distill 選文。zh-only，不走 BlogPost layout（那會推導出不存在的 EN twin）。
import { getCollection, render } from "astro:content";
import Base from "../../../layouts/Base.astro";

export async function getStaticPaths() {
  const entries = await getCollection("distill");
  return entries.map((entry) => ({
    params: { slug: entry.data.postSlug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fm = entry.data;

const CHANNEL_META = {
  "data-engineering": { label: "資料工程", section: "/zh/distill/data-engineering/" },
  money: { label: "理財", section: "/zh/distill/money/" },
};
const ch = CHANNEL_META[fm.channel] ?? CHANNEL_META["data-engineering"];

const alternateUrls = { en: "/", zh: `/zh/distill/${fm.postSlug}/` };
---

<Base
  title={`${fm.title} — Distill 選文`}
  description={fm.description}
  lang="zh"
  alternateUrls={alternateUrls}
>
  <main class="px-6 md:px-10 py-20 md:py-24">
    <article class="max-w-3xl mx-auto">
      <a
        href={ch.section}
        class="font-mono text-xs text-ink-500 hover:text-ink-900 transition-colors"
      >
        ← 回{ch.label}選文列表
      </a>

      <header class="mt-8 mb-10 pb-8 border-b border-ink-200">
        <span
          class="inline-block font-mono text-[11px] uppercase tracking-widest text-ink-500 border border-ink-200 rounded-full px-2.5 py-1 mb-6"
        >
          Distill · {ch.label}
        </span>
        <h1
          class="text-2xl md:text-[1.95rem] font-semibold tracking-tight text-ink-900 leading-[1.3]"
        >
          {fm.title}
        </h1>
        <div
          class="mt-5 flex flex-wrap gap-x-5 gap-y-2 font-mono text-[12px] text-ink-500"
        >
          <span>{fm.date}</span>
          <a
            href={fm.sourceUrl}
            target="_blank"
            rel="noreferrer nofollow"
            class="text-ink-500 hover:text-ink-900 transition-colors border-b border-ink-200 hover:border-ink-500"
          >
            原文{fm.sourceName ? `：${fm.sourceName}` : ""}
          </a>
          {
            fm.threadUrl && (
              <a
                href={fm.threadUrl}
                target="_blank"
                rel="noreferrer"
                class="text-ink-500 hover:text-ink-900 transition-colors border-b border-ink-200 hover:border-ink-500"
              >
                Threads 討論
              </a>
            )
          }
        </div>
      </header>

      <div class="blog-prose">
        <Content />
      </div>
    </article>
  </main>
</Base>
