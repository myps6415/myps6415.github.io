---
// Content automation case study + services page (English). B2B lead-gen.
// Distill is the live portfolio; this is the shared trust asset for
// ① subscription service / ② project work / ③ course.
import Base from "../../layouts/Base.astro";

const stats = [
  { n: "3", unit: "channels", note: "running (＋2 retired)" },
  { n: "240+", unit: "posts", note: "auto-published" },
  { n: "~40k", unit: "views／mo", note: "top single post 7,000+" },
  { n: "0", unit: "daily human ops", note: "topic pick → publish, automated" },
];

const pipeline = [
  ["Pick", "Selects topics from dozens of frontline RSS / radar sources — deterministic code de-dupes and filters off-topic items, no LLM guessing."],
  ["Fetch source", "Pulls the full article as the single source of truth; skips the cycle if it can't — never fabricates from a headline."],
  ["Rewrite", "Rewrites in Traditional Chinese in its own words, applying a 14-point \"de-AI\" checklist and proven first-line hooks — not machine translation."],
  ["Fact-check", "Every place name / proper noun must appear in the source, or the draft is rejected and rewritten — stops AI hallucination."],
  ["Publish", "Auto-schedules to each channel; images, source comments, length and formatting all handled automatically."],
  ["Sediment", "Each post also becomes a page on an owned website — a long-term, Google-indexed asset (the site you're on)."],
  ["Feed back", "Collects reach data daily; weekly it distills \"which opening line works\" back into strategy, so the system keeps getting sharper."],
];

const rigor = [
  ["Fact-check gate", "Place names / proper nouns must match the source or the draft bounces. Once caught a piece that placed an Osaka shop in Tokyo."],
  ["Four-layer publish defense", "Even if the writer crashes mid-run, no empty image-only post ships — four independent guardrails."],
  ["De-AI self-audit", "A 14-point checklist strips canned phrasing and filler so readers can't tell a machine wrote it."],
  ["Data-driven", "First-line structure isn't a guess — it's distilled from real reach data (a 20× spread between best and worst)."],
];

const offers = [
  ["Custom build", "I build a content-automation pipeline for your brand or company, delivered once — you own the system."],
  ["Managed subscription", "Don't want to run it yourself? I operate this system to produce your channel's content daily — monthly subscription, fully automated delivery."],
  ["Course / advisory", "Want to learn it? An online course and one-on-one advisory to hand the whole method to your team."],
];

const alternateUrls = { en: "/services/", zh: "/zh/services/" };
---

<Base
  title="Content Automation — Case Study & Working Together｜Hsiao-Yu Tung"
  description="One Mac, one automation system: distills frontline foreign content into Chinese, auto-publishes across social channels, and sediments it into an owned asset. Case study, how it works, and ways to work together."
  lang="en"
  alternateUrls={alternateUrls}
>
  <main class="px-6 md:px-10 py-20 md:py-28">
    <div class="max-w-3xl mx-auto">
      <a
        href="/"
        class="font-mono text-xs text-ink-500 hover:text-ink-900 transition-colors"
      >
        ← Home
      </a>

      <p class="mt-8 font-mono text-xs uppercase tracking-widest text-ink-500 mb-6">
        Case Study
      </p>
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-ink-900 mb-5 leading-[1.25]">
        One Mac, running multiple content channels on autopilot
      </h1>
      <p class="text-ink-700 leading-relaxed text-lg mb-4">
        Distill is a content-automation system I built: every day it picks topics from
        frontline foreign blogs and papers, rewrites them in Traditional Chinese,
        fact-checks them, auto-publishes to multiple social channels, and sediments
        them into an owned website. It all runs on a single Mac — zero daily human ops.
      </p>
      <p class="text-ink-700 leading-relaxed mb-12">
        This site is one of its outputs. Here's how it works — and why it's more than
        "have an AI write something."
      </p>

      <!-- stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-ink-200 border border-ink-200 rounded-lg overflow-hidden mb-14">
        {
          stats.map((s) => (
            <div class="bg-white p-5">
              <div class="text-2xl md:text-3xl font-semibold text-ink-900 tracking-tight">
                {s.n}
              </div>
              <div class="font-mono text-[11px] uppercase tracking-widest text-ink-500 mt-1">
                {s.unit}
              </div>
              <div class="text-[0.8rem] text-ink-700 mt-2 leading-snug">{s.note}</div>
            </div>
          ))
        }
      </div>

      <!-- problem -->
      <section class="mb-14">
        <h2 class="text-xl font-semibold text-ink-900 tracking-tight mb-3">The problem</h2>
        <p class="text-ink-700 leading-relaxed">
          Running content at scale usually takes a whole editorial team: find topics,
          translate, rewrite, format, publish, watch the numbers. Point a raw AI at it
          and you get obviously-machine text — sometimes with the facts wrong. Distill's
          goal: automate the entire line while holding the bar at "reads like a human,
          and doesn't get things wrong."
        </p>
      </section>

      <!-- how it works -->
      <section class="mb-14">
        <h2 class="text-xl font-semibold text-ink-900 tracking-tight mb-5">How it works</h2>
        <ol class="space-y-4">
          {
            pipeline.map(([step, desc], i) => (
              <li class="flex gap-4">
                <span class="font-mono text-xs text-ink-500 pt-1 w-5 shrink-0">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div>
                  <div class="font-semibold text-ink-900 text-[0.95rem]">{step}</div>
                  <div class="text-ink-700 leading-relaxed text-[0.9rem]">{desc}</div>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <!-- rigor -->
      <section class="mb-14">
        <h2 class="text-xl font-semibold text-ink-900 tracking-tight mb-2">
          Why it's not "just ask ChatGPT"
        </h2>
        <p class="text-ink-700 leading-relaxed mb-5">
          The difference is engineering. This system treats "don't get it wrong" as a
          reliability problem, not a roll of the dice:
        </p>
        <ul class="divide-y divide-ink-200 border-t border-b border-ink-200">
          {
            rigor.map(([title, desc]) => (
              <li class="py-4">
                <div class="font-semibold text-ink-900 text-[0.95rem] mb-1">{title}</div>
                <div class="text-ink-700 leading-relaxed text-[0.9rem]">{desc}</div>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- who -->
      <section class="mb-14">
        <h2 class="text-xl font-semibold text-ink-900 tracking-tight mb-3">Who built it</h2>
        <p class="text-ink-700 leading-relaxed">
          I'm Hsiao-Yu Tung, a Principal Data Engineer. My day job is exactly this:
          taking social-platform data end-to-end into a warehouse and keeping it running
          on schedules and models. Distill applies the same engineering to content
          production — pick, rewrite, verify, publish, sediment, feed back — where every
          stage is maintainable automation, not a one-off demo.
        </p>
      </section>

      <!-- CTA -->
      <section class="border-t border-ink-200 pt-10">
        <h2 class="text-xl font-semibold text-ink-900 tracking-tight mb-5">Ways to work together</h2>
        <ul class="space-y-4 mb-8">
          {
            offers.map(([title, desc]) => (
              <li>
                <div class="font-semibold text-ink-900 text-[0.95rem]">{title}</div>
                <div class="text-ink-700 leading-relaxed text-[0.9rem]">{desc}</div>
              </li>
            ))
          }
        </ul>
        <div class="flex flex-wrap gap-x-6 gap-y-3 font-mono text-sm">
          <a
            href="mailto:myps6415@gmail.com?subject=Distill%20content%20automation%20—%20inquiry"
            class="text-ink-900 border-b border-ink-300 hover:border-ink-900 transition-colors"
          >
            ✉ Get in touch: myps6415@gmail.com
          </a>
          <a
            href="https://www.threads.com/@myps6415"
            target="_blank"
            rel="noopener noreferrer"
            class="text-ink-500 hover:text-ink-900 border-b border-ink-200 hover:border-ink-500 transition-colors"
          >
            See it live → Threads @myps6415
          </a>
        </div>
      </section>
    </div>
  </main>
</Base>
