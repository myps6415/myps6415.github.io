---
import Base from "../../layouts/Base.astro";
import { content } from "../../i18n/strings";
import { getSortedPosts, postPath } from "../../data/posts";

const posts = await getSortedPosts("en");
const c = content.en;
const w = c.writing;

const alternateUrls = { en: "/blog/", zh: "/zh/blog/" };
---

<Base
  title={w.indexTitle}
  description={w.indexDescription}
  lang="en"
  alternateUrls={alternateUrls}
>
  <main class="px-6 md:px-10 py-20 md:py-28">
    <div class="max-w-3xl mx-auto">
      <a
        href="/"
        class="font-mono text-xs text-ink-500 hover:text-ink-900 transition-colors"
      >
        ← Home
      </a>
      <p
        class="mt-8 font-mono text-xs uppercase tracking-widest text-ink-500 mb-6"
      >
        {w.label}
      </p>
      <h1
        class="text-3xl md:text-4xl font-semibold tracking-tight text-ink-900 mb-12"
      >
        {w.intro}
      </h1>

      <ul class="divide-y divide-ink-200 border-t border-b border-ink-200">
        {
          posts.map((p) => {
            const loc = p;
            const href = postPath(p.slug, "en");
            return (
              <li>
                <a
                  href={href}
                  class="group block py-6 transition-colors hover:bg-white -mx-3 px-3 rounded-md"
                >
                  <div class="flex items-baseline justify-between gap-4 mb-2 flex-wrap">
                    <span class="font-mono text-[11px] uppercase tracking-widest text-ink-500">
                      {loc.tag}
                    </span>
                    <span class="font-mono text-[11px] text-ink-500">
                      {p.date}
                    </span>
                  </div>
                  <h2 class="text-lg md:text-xl font-semibold text-ink-900 tracking-tight leading-snug mb-2 group-hover:underline underline-offset-4 decoration-ink-300">
                    {loc.title}
                  </h2>
                  <p class="text-ink-700 leading-relaxed text-[0.95rem]">
                    {loc.description}
                  </p>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </main>
</Base>
